# 백엔드 연동 여부 (false=실서버, 미설정/그 외=mock)
VITE_USE_MOCK=false

# 네이버 지도(NCP Maps) 인증 키 — 여행 기록 지도(TripMapView)에서 사용
# NCP 콘솔 > Maps 애플리케이션의 Client ID 를 넣는다.
# 실제 키는 .env.local 에 넣고 커밋하지 않는다(*.local 은 gitignore 됨).
VITE_NAVER_MAP_CLIENT_ID=

# (선택) SDK 스크립트 파라미터명. 신규 NCP 콘솔 키는 ncpKeyId(기본값),
# 구 콘솔(AI·NAVER API) 키라면 ncpClientId 로 바꾼다.
# VITE_NAVER_MAP_KEY_PARAM=ncpKeyId
